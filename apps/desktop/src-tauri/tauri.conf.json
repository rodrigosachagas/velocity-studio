{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velocity Studio",
  "version": "0.1.0",
  "identifier": "studio.velocity.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Velocity Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
